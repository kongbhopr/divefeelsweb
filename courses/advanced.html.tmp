<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>คอร์สดำน้ำ Advanced Open Water Diver กรุงเทพ | Dive Feels SSI</title>
  <meta name="description" content="เรียน Advanced Open Water Diver ในกรุงเทพ ฝึกสระ จบ cert ที่พัทยา ไม่ต้องออกเกาะ ตารางยืดหยุ่น SSI Certified สอบถาม LINE ได้เลย">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@400;500;600;700&family=Sarabun:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-navy-deep:    #1C2B3A;
      --color-navy-ocean:   #2E4A6A;
      --color-teal:         #5BA8B8;
      --color-red:          #E31837;
      --color-coral:        #FF9B7A;
      --color-bg:           #FFF6F0;
      --color-white:        #FFFFFF;
      --color-surface:      #F5EDE8;
      --color-border:       #E8DDD8;
      --color-text-primary: #1C2B3A;
      --color-text-body:    #3D4F5C;
      --color-text-muted:   #7A8C99;
      --color-teal-tint-1:  #EAF5F7;
      --font-heading: 'Prompt', system-ui, sans-serif;
      --font-body:    'Sarabun', system-ui, sans-serif;
      --shadow-sm: 0 1px 3px rgba(28,43,58,.08);
      --shadow-md: 0 4px 12px rgba(28,43,58,.10);
      --shadow-lg: 0 8px 24px rgba(28,43,58,.12);
      --radius-md: 8px;
      --radius-lg: 12px;
      --radius-full: 9999px;
      --transition-base: 250ms ease;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); font-size: 1rem; line-height: 1.7; color: var(--color-text-body); background: var(--color-bg); }
    img { max-width: 100%; height: auto; display: block; }
    a { color: var(--color-teal); text-decoration: none; }
    h1,h2,h3,h4 { font-family: var(--font-heading); color: var(--color-text-primary); line-height: 1.3; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: var(--color-navy-deep);
      padding: 0 24px; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,.2);
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-logo img { height: 36px; }
    .nav-logo-text { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #fff; }
    .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
    .nav-links a { color: rgba(255,255,255,.8); font-size: .9rem; font-family: var(--font-heading); transition: color var(--transition-base); }
    .nav-links a:hover { color: var(--color-teal); }
    .nav-cta { background: var(--color-red); color: #fff !important; padding: 8px 18px; border-radius: var(--radius-full); font-weight: 600 !important; }
    .nav-cta:hover { background: #C4142E; color: #fff !important; }
    @media (max-width: 768px) {
      .nav-links { display: none; }
    }

    /* BREADCRUMB */
    .breadcrumb {
      background: var(--color-surface);
      padding: 12px 0;
      font-size: .85rem;
      color: var(--color-text-muted);
    }
    .breadcrumb a { color: var(--color-teal); }
    .breadcrumb span { margin: 0 6px; }

    /* HERO */
    .course-hero {
      background: linear-gradient(135deg, var(--color-navy-deep) 0%, var(--color-navy-ocean) 100%);
      color: #fff;
      padding: 64px 0;
      position: relative;
      overflow: hidden;
    }
    .course-hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url('../assets/images/diver-silhouette.jpg') center/cover no-repeat;
      opacity: .18;
    }
    .course-hero-inner {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center;
    }
    .course-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(91,168,184,.25); color: var(--color-teal);
      font-size: .75rem; font-weight: 700; font-family: var(--font-heading);
      letter-spacing: .08em; text-transform: uppercase;
      padding: 4px 14px; border-radius: var(--radius-full);
      border: 1px solid rgba(91,168,184,.4);
      margin-bottom: 16px;
    }
    .course-hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; margin-bottom: 16px; }
    .course-hero-sub { font-size: 1.05rem; color: rgba(255,255,255,.8); margin-bottom: 28px; line-height: 1.8; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 32px; }
    .hero-meta-item { display: flex; align-items: center; gap: 8px; font-size: .9rem; color: rgba(255,255,255,.85); }
    .hero-meta-item strong { color: #fff; }
    .hero-cta-group { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: var(--radius-full); font-family: var(--font-heading); font-weight: 600; font-size: .95rem; cursor: pointer; border: none; transition: all var(--transition-base); text-decoration: none; }
    .btn-red { background: var(--color-red); color: #fff; }
    .btn-red:hover { background: #C4142E; transform: translateY(-1px); }
    .btn-outline-white { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.4); }
    .btn-outline-white:hover { border-color: #fff; background: rgba(255,255,255,.1); }
    .btn-teal { background: var(--color-teal); color: #fff; }
    .btn-teal:hover { background: #4A97A8; transform: translateY(-1px); }

    /* COURSE CARD (sticky sidebar) */
    .course-card-sticky {
      background: var(--color-white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
    }
    .course-card-img {
      height: 180px;
      background: url('../assets/images/pool-training.jpg') center/cover no-repeat;
    }
    .course-card-body { padding: 24px; }
    .price-label { font-size: .8rem; color: var(--color-text-muted); margin-bottom: 4px; }
    .price-value { font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; color: var(--color-navy-deep); margin-bottom: 4px; }
    .price-note { font-size: .8rem; color: var(--color-text-muted); margin-bottom: 20px; }
    .course-card-meta { border-top: 1px solid var(--color-border); padding-top: 16px; margin-top: 4px; display: flex; flex-direction: column; gap: 10px; }
    .course-card-meta-row { display: flex; justify-content: space-between; font-size: .875rem; }
    .course-card-meta-row span:first-child { color: var(--color-text-muted); }
    .course-card-meta-row strong { color: var(--color-text-primary); font-weight: 600; }
    @media (max-width: 900px) {
      .course-hero-inner { grid-template-columns: 1fr; }
      .course-card-sticky { max-width: 400px; }
    }

    /* CONTENT SECTIONS */
    .section { padding: 64px 0; }
    .section-alt { background: var(--color-surface); }
    .section-label {
      display: inline-block;
      font-size: .75rem; font-weight: 700; font-family: var(--font-heading);
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--color-teal); margin-bottom: 10px;
    }
    .section-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; margin-bottom: 16px; }
    .section-intro { color: var(--color-text-muted); font-size: 1.05rem; max-width: 620px; line-height: 1.8; margin-bottom: 36px; }

    /* INCLUDES GRID */
    .includes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
    .include-item {
      background: var(--color-white);
      border-radius: var(--radius-md);
      padding: 20px;
      display: flex; gap: 14px; align-items: flex-start;
      box-shadow: var(--shadow-sm);
    }
    .include-icon { font-size: 1.5rem; flex-shrink: 0; }
    .include-text h4 { font-size: .95rem; font-weight: 600; margin-bottom: 4px; }
    .include-text p { font-size: .85rem; color: var(--color-text-muted); line-height: 1.5; }

    /* STEPS */
    .steps { display: flex; flex-direction: column; gap: 0; }
    .step {
      display: grid; grid-template-columns: 56px 1fr; gap: 24px;
      padding: 28px 0; border-bottom: 1px solid var(--color-border);
      align-items: flex-start;
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 48px; height: 48px; border-radius: 50%;
      background: var(--color-navy-ocean); color: #fff;
      font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .step-content h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 6px; }
    .step-content p { color: var(--color-text-muted); font-size: .9rem; line-height: 1.7; }
    .step-badge {
      display: inline-flex; align-items: center; gap: 4px;
      background: var(--color-teal-tint-1); color: var(--color-navy-ocean);
      font-size: .72rem; font-weight: 700; font-family: var(--font-heading);
      padding: 2px 10px; border-radius: var(--radius-full);
      margin-bottom: 6px;
    }

    /* SKILLS TABLE */
    .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 600px) { .skills-grid { grid-template-columns: 1fr; } }
    .skill-item {
      display: flex; align-items: center; gap: 10px;
      background: var(--color-white); padding: 14px 18px;
      border-radius: var(--radius-md); box-shadow: var(--shadow-sm);
      font-size: .9rem;
    }
    .skill-item::before { content: '✓'; color: var(--color-teal); font-weight: 700; font-size: 1rem; flex-shrink: 0; }

    /* FAQ MINI */
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    .faq-item {
      background: var(--color-white);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }
    .faq-q {
      width: 100%; text-align: left;
      padding: 18px 22px;
      font-family: var(--font-heading); font-size: .95rem; font-weight: 600;
      background: none; border: none; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
      color: var(--color-text-primary);
    }
    .faq-q .arrow { transition: transform var(--transition-base); font-size: .8rem; color: var(--color-text-muted); }
    .faq-item.open .faq-q .arrow { transform: rotate(180deg); }
    .faq-a { display: none; padding: 0 22px 18px; font-size: .9rem; color: var(--color-text-muted); line-height: 1.7; border-top: 1px solid var(--color-border); padding-top: 14px; }
    .faq-item.open .faq-a { display: block; }

    /* CTA BANNER */
    .cta-banner {
      background: linear-gradient(135deg, var(--color-navy-deep), var(--color-navy-ocean));
      color: #fff; text-align: center; padding: 64px 24px;
    }
    .cta-banner h2 { font-size: clamp(1.4rem, 3vw, 2rem); margin-bottom: 12px; }
    .cta-banner p { color: rgba(255,255,255,.75); margin-bottom: 32px; font-size: 1.05rem; }
    .cta-group { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

    /* FOOTER */
    footer {
      background: var(--color-navy-deep);
      color: rgba(255,255,255,.6);
      padding: 40px 24px;
      text-align: center;
      font-size: .85rem;
    }
    footer a { color: var(--color-teal); }
    .footer-links { display: flex; gap: 24px; justify-content: center; margin-bottom: 16px; flex-wrap: wrap; }

    /* STICKY LINE BTN */
    .sticky-line-btn {
      position: fixed; bottom: 24px; right: 24px; z-index: 200;
      background: #06C755; color: #fff;
      width: 56px; height: 56px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 16px rgba(6,199,85,.4);
      font-size: 1.5rem; text-decoration: none;
      transition: transform var(--transition-base);
    }
    .sticky-line-btn:hover { transform: scale(1.1); }

    /* RELATED COURSES */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
    .related-card {
      background: var(--color-white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      transition: transform var(--transition-base), box-shadow var(--transition-base);
      text-decoration: none; color: inherit;
      display: block;
    }
    .related-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .related-card-img { height: 140px; background-size: cover; background-position: center; }
    .related-card-body { padding: 18px; }
    .related-card-body h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
    .related-card-body p { font-size: .85rem; color: var(--color-text-muted); }
  </style>

  <!-- FAQPage + Course Schema -->
